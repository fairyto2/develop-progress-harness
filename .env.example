# OpenTelemetry Configuration
# Endpoint for the OTel Collector gRPC receiver
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# GitLab Integration
# Personal access token for glab CLI (required for GitLab issue tracking)
GITLAB_TOKEN=glpat-xxxxx
# GitLab instance host URL
GITLAB_HOST=https://gitlab.com
# Target GitLab project in owner/repo format
GITLAB_PROJECT=myorg/myproject

# Claude Code User Identification
# User identifier for individual-level metrics and dashboard filtering
CLAUDE_USER_NAME=developer-name

# Grafana Configuration
# Admin password for Grafana (default: admin for local development)
GF_SECURITY_ADMIN_PASSWORD=admin
